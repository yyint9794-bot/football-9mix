# Htay API
VITE_HTAY_API_KEY=demoapi
VITE_HTAY_FOOTBALL_VERSION=v7

# Telegram
VITE_TELEGRAM_URL=https://t.me/yourchannel

# Google AdSense — ငွေရှာရန် ca-pub ID (https://www.google.com/adsense)
# Auto ads: dashboard မှာ ON လုပ်ပါ — slot မလိုသေးပါ
VITE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
# Site verification meta (optional)
VITE_ADSENSE_VERIFICATION=
VITE_ADSENSE_SLOT_TOP=
VITE_ADSENSE_SLOT_INLINE=
VITE_ADSENSE_SLOT_BOTTOM=
# Betting hub / odds screens (falls back to INLINE if empty)
VITE_ADSENSE_SLOT_BET=
# Deposit / withdraw (falls back to INLINE if empty)
VITE_ADSENSE_SLOT_PAYMENT=
# Live player modal (falls back to INLINE if empty)
VITE_ADSENSE_SLOT_LIVE=

# Optional pre-roll video ad (mp4 URL)
VITE_VIDEO_AD_URL=

# Payment display (local dev only; production uses wrangler / Pages vars)
VITE_WALLET_KPAY_NUMBER=09674646102
VITE_WALLET_WAVE_NUMBER=09674646102
