rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /live_rooms/{roomId} {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasAll(['updatedAt'])
        && request.resource.data.updatedAt is number;
      allow delete: if false;
    }
    match /live_rooms/{roomId}/messages/{messageId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['userId', 'displayName', 'text', 'createdAt'])
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 400
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 24
        && request.resource.data.userId is string
        && request.resource.data.userId.size() > 0
        && request.resource.data.createdAt is number;
      allow update, delete: if false;
    }
  }
}
