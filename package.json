{
  "name": "football-stream-hub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "phone": "node scripts/phone-url.mjs",
    "share": "node scripts/share-phone.mjs",
    "phone:share": "node scripts/phone-share.mjs",
    "build": "vite build",
    "typecheck": "tsc -b",
    "preview": "vite preview --host 0.0.0.0",
    "pages:dev": "npm run build && wrangler pages dev dist --compatibility-flags=nodejs_compat"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "hls.js": "^1.6.16",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3"
  },
  "engines": {
    "node": ">=20"
  }
}
